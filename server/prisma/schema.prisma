// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  profile      UserProfile?
  applications JobApplication[]
}

model UserProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String?
  professionalTitle String?
  contactInfo       String?   // Email, phone, LinkedIn URL, etc.
  skills            String?   // JSON or comma-separated skills
  cvFilePath        String?   // Path to uploaded CV file
  cvParsedText      String?   // Extracted text from CV for AI processing
  cvFileName        String?   // Original CV file name
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model JobApplication {
  id              String   @id @default(uuid())
  companyName     String
  jobTitle        String
  status          String   @default("PENDING")
  jobDescription  String?
  link            String?  // שדה חדש (סימן השאלה אומר שהוא רשות)
  notes           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
}